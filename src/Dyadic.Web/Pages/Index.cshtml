@page
@model IndexModel
@{
    ViewData["Title"] = "Home";
}

<div class="text-center py-5">
    <h1 class="display-4 fw-bold">Dyadic</h1>
    <p class="lead text-muted md-4">
        A blind proposal matching system - connecting student research proposals to academic supervisors fairly and transparently. 
    </p>
    <div class="d-flex justify-content-center gap-3">
        <a asp-page="/Account/Register" class="btn btn-lg text-white" style="background-color: #009b5f;">Get Started</a>
        <a asp-page="/Account/Login" class="btn btn-lg" style="color: #009b5f; border-color: #009b5f;">Login</a>
    </div>
</div>
